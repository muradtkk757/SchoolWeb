<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FutureAcademy</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <style>
        body { font-family: 'Plus Jakarta Sans', sans-serif; background-color: #f8f9fa; }
        .top-navbar { background-color: #ffffff; box-shadow: 0 2px 15px rgba(0,0,0,0.03); }
        .dropdown-menu { border: 1px solid #e9ecef; }
    </style>
</head>
<body class="d-flex flex-column h-100 min-vh-100">

    <header class="navbar navbar-expand-md top-navbar py-2 sticky-top z-3">
        <div class="container">
            <a class="navbar-brand fw-bold d-flex align-items-center text-dark text-decoration-none" href="/StudentPanel/Attendance">
                <div class="bg-success bg-opacity-10 text-success p-2 rounded-3 me-2 d-flex align-items-center justify-content-center">
                    <i class="bi bi-book-half" style="font-size: 1.2rem; line-height: 1;"></i>
                </div>
                <span class="fs-4">Student<span class="text-success">Portal</span></span>
            </a>
            
            <div class="d-flex align-items-center ms-auto gap-3">
                <a href="/" class="btn btn-sm btn-outline-secondary rounded-pill px-3 d-none d-md-block">
                    <i class="bi bi-house-door me-1"></i> Main Site
                </a>
                <div class="dropdown">
                    <a href="#" class="d-flex align-items-center text-dark text-decoration-none dropdown-toggle rounded-pill p-1 pe-3" style="background:#f8f9fa" id="dropdownUser" data-bs-toggle="dropdown" aria-expanded="false">
                        <img src="https://ui-avatars.com/api/?name=Student&background=198754&color=fff&rounded=true&bold=true" alt="mdo" width="40" height="40" class="rounded-circle shadow-sm me-2">
                        <div class="text-start d-none d-sm-block">
                            <span class="d-block fw-bold fs-6 lh-1">My Avatar</span>
                        </div>
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end rounded-4 mt-2 py-2 shadow-lg" aria-labelledby="dropdownUser">
                        <li><a class="dropdown-item py-2 text-danger fw-semibold" href="/Account/Logout"><i class="bi bi-box-arrow-right me-2"></i> Log out</a></li>
                    </ul>
                </div>
            </div>
        </div>
    </header>

    <div class="container flex-grow-1 overflow-hidden py-4">
        @RenderBody()
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>