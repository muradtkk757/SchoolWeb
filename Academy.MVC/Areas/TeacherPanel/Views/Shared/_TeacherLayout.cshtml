<!DOCTYPE html>
<html lang="en" class="h-100">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FutureAcademy Teacher Panel</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Academy.MVC.styles.css" asp-append-version="true" />
    <!-- Fonts and Icons -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    
    <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f4f7fe; /* Soft light gray/blue background */
        }

        /* Sidebar Styling - Light & Clean */
        #sidebarMenu {
            background-color: #ffffff;
            min-height: calc(100vh - 70px);
            border-right: 1px solid #e9ecef;
            z-index: 100;
        }

        .nav-link {
            color: #6c757d !important; /* Soft gray */
            padding: 0.85rem 1.25rem;
            margin-bottom: 0.25rem;
            border-radius: 0.5rem;
            font-weight: 500;
            display: flex;
            align-items: center;
            transition: all 0.2s ease-in-out;
        }
        
        .nav-link i {
            font-size: 1.25rem;
            margin-right: 1rem;
            color: #adb5bd;
            transition: color 0.2s ease;
        }

        .nav-link:hover {
            background-color: #f8f9fa;
            color: #212529 !important;
        }
        
        .nav-link:hover i {
            color: #2b3abf;
        }

        .nav-link.active-link {
            color: #2b3abf !important; /* Deep blue text */
            background-color: #f0f3ff; /* Very light blue bg */
            font-weight: 600;
        }
        
        .nav-link.active-link i {
            color: #2b3abf;
        }

        /* Top Navbar Styling - Bright & Clean */
        .top-navbar {
            background-color: #ffffff;
            height: 70px;
            border-bottom: 1px solid #e9ecef;
        }

        .navbar-brand-wrapper {
            background-color: #ffffff;
            font-weight: 700;
            border-right: 1px solid #e9ecef;
            color: #212529 !important;
        }

        /* Main Content Area */
        main {
            min-height: calc(100vh - 70px);
            padding: 2rem !important;
        }

        .dropdown-menu {
            border: 1px solid #e9ecef;
            box-shadow: 0 0.5rem 1rem rgba(0, 0, 0, 0.05);
        }
    </style>
</head>
<body class="d-flex flex-column h-100">

    <header class="navbar navbar-expand-md top-navbar p-0 sticky-top z-3">
        <!-- Brand/Logo Area -->
        <a class="navbar-brand-wrapper col-md-3 col-lg-2 me-0 px-4 py-3 d-flex align-items-center text-decoration-none h-100" href="/TeacherPanel/Group">
            <div class="bg-primary bg-opacity-10 p-2 rounded-3 me-2 d-flex align-items-center justify-content-center">
                <i class="bi bi-mortarboard-fill text-primary" style="font-size: 1.2rem; line-height: 1;"></i>
            </div>
            <span class="fs-5" style="letter-spacing: -0.5px;">Teacher<span class="text-primary">Panel</span></span>
        </a>
        
        <!-- Top Nav Items -->
        <div class="d-flex align-items-center w-100 justify-content-between px-4">
            
            <button class="navbar-toggler border-0 shadow-none px-2 text-dark" type="button" data-bs-toggle="collapse" data-bs-target="#sidebarMenu" aria-controls="sidebarMenu">
                <i class="bi bi-list fs-2"></i>
            </button>

            <!-- Right side / Profile Dropdown -->
            <div class="d-flex align-items-center ms-auto">
                <div class="dropdown">
                    <a href="#" class="d-flex align-items-center text-dark text-decoration-none dropdown-toggle py-2 rounded-pill hover-bg-light" id="dropdownUser1" data-bs-toggle="dropdown" aria-expanded="false">
                        <div class="text-end me-3 d-none d-md-block">
                            <span class="d-block fw-bold fs-6 lh-1" style="color: #2b3abf;">My Profile</span>
                            <small class="text-muted" style="font-size: 0.75rem;">Teacher Account</small>
                        </div>
                        <img src="https://ui-avatars.com/api/?name=Teacher&background=2b3abf&color=fff&rounded=true&bold=true" alt="mdo" width="40" height="40" class="rounded-circle shadow-sm">
                    </a>
                    <ul class="dropdown-menu dropdown-menu-end rounded-3 mt-2 py-2" aria-labelledby="dropdownUser1" style="min-width: 200px;">
                        <li><h6 class="dropdown-header text-uppercase fw-bold text-muted small tracking-wider">Account</h6></li>
                        <li>
                            <a class="dropdown-item py-2 fw-medium text-secondary" href="#">
                                <i class="bi bi-gear me-2"></i> Settings
                            </a>
                        </li>
                        <li><hr class="dropdown-divider my-2"></li>
                        <li>
                            <!-- Direct href is much more reliable than asp tag helpers in areas -->
                            <a class="dropdown-item py-2 text-danger fw-semibold" href="/Account/Logout">
                                <i class="bi bi-box-arrow-right me-2"></i> Sign out
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </header>

    <div class="container-fluid flex-grow-1 overflow-hidden">
        <div class="row h-100">
            
            <!-- Sidebar -->
            <nav id="sidebarMenu" class="col-md-3 col-lg-2 d-md-block sidebar collapse px-3 pt-4">
                <div class="text-uppercase text-muted fw-bold mb-2 px-2" style="font-size: 0.7rem; letter-spacing: 1px;">Core Navigation</div>
                <ul class="nav flex-column gap-1 mb-4">
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Group" ? "active-link" : "")" href="/TeacherPanel/Group">
                            <i class="bi bi-grid-1x2-fill"></i> My Classes
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Students" ? "active-link" : "")" href="/TeacherPanel/Students">
                            <i class="bi bi-people-fill"></i> Students List
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Attendance" ? "active-link" : "")" href="/TeacherPanel/Attendance">
                            <i class="bi bi-clipboard2-check-fill"></i> Attendance
                        </a>
                    </li>
                </ul>

                <div class="text-uppercase text-muted fw-bold mb-2 px-2" style="font-size: 0.7rem; letter-spacing: 1px;">Quick Links</div>
                <ul class="nav flex-column gap-1">
                    <li class="nav-item">
                        <!-- Works 100% of the time to go to the main page -->
                        <a class="nav-link text-primary bg-primary bg-opacity-10 fw-bold" href="/">
                            <i class="bi bi-house-door-fill text-primary"></i> Back to Main Site
                        </a>
                    </li>
                </ul>
                
                <!-- Sidebar Footer -->
                <div class="mt-auto px-4 py-4 text-center position-absolute bottom-0 w-100 pb-3" style="font-size: 0.75rem; color: #adb5bd;">
                    <span class="fw-medium text-dark">FutureAcademy</span><br/>
                    &copy; 2026 Edu System
                </div>
            </nav>

            <!-- Page Content -->
            <main class="col-md-9 ms-sm-auto col-lg-10 overflow-y-auto" style="height: calc(100vh - 70px);">
                <div class="container-fluid p-0">
                    @RenderBody()
                </div>
            </main>
            
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>