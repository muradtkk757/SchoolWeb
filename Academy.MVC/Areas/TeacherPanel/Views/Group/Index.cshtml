
@model IEnumerable<Academy.BLL.DTOs.GroupDto>

@{
    ViewData["Title"] = "Groups";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Groups</h2>
    <span class="badge text-bg-dark px-3 py-2">Total: @Model.Count()</span>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert alert-warning" role="alert">
        @ViewBag.Error
    </div>
}

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-4">#</th>
                    <th>Group Name</th>
                    <th>Teacher</th>
                    <th class="text-end pe-4">Students</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    foreach (var group in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-semibold">@group.Id</td>
                            <td>@group.Name</td>
                            <td>@(string.IsNullOrWhiteSpace(group.TeacherName) ? "-" : group.TeacherName)</td>
                            <td class="text-end pe-4">@group.Students.Count()</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-4">No groups found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

