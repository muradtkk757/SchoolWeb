
@model IEnumerable<Academy.BLL.DTOs.GroupDto>

@{
    ViewData["Title"] = "Groups";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Groups</h2>
    <span class="badge text-bg-dark px-3 py-2">Total: @Model.Count()</span>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert alert-warning" role="alert">
        @ViewBag.Error
    </div>
}

<div class="card border-0 shadow-sm rounded-4 overflow-hidden">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr>
                    <th class="ps-4">#</th>
                    <th>Group Name</th>
                    <th class="text-end pe-4">Students</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Any())
                {
                    foreach (var group in Model)
                    {
                        var studentCount = group.Students.Count();
                        var collapseId = $"students-{group.Id}";

                        <tr>
                            <td class="ps-4 fw-semibold">@group.Id</td>
                            <td>@group.Name</td>
                            <td class="text-end pe-4">
                                <span class="badge rounded-pill text-bg-secondary me-2">@studentCount</span>
                                <button class="btn btn-sm btn-outline-dark rounded-pill px-3"
                                        type="button"
                                        data-bs-toggle="collapse"
                                        data-bs-target="#@collapseId"
                                        aria-expanded="false"
                                        aria-controls="@collapseId">
                                    View Students
                                </button>
                                <div class="collapse mt-3 text-start" id="@collapseId">
                                    @if (studentCount > 0)
                                    {
                                        <div class="d-flex flex-wrap gap-2 justify-content-end">
                                            @foreach (var student in group.Students)
                                            {
                                                <span class="badge rounded-pill text-bg-dark px-3 py-2">@student.Name</span>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted">No students assigned to this group yet.</span>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="3" class="text-center text-muted py-4">No groups found.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

