@model IEnumerable<Academy.BLL.DTOs.AttendanceDto>
@{
    ViewData["Title"] = "Attendance History";
}

<div class="row align-items-center mb-4">
    <div class="col-md-8">
        <h2 class="display-6 fw-bold text-dark mb-1">Attendance History</h2>
        <p class="text-muted fw-medium d-flex align-items-center">
            <span class="badge bg-primary bg-opacity-10 text-primary me-2 px-3 py-1 border border-primary border-opacity-25 rounded-pill">Class @ViewBag.GroupName</span>
            Review past recorded attendances.
        </p>
    </div>
    <div class="col-md-4 text-md-end">
        <a asp-action="Index" class="btn btn-outline-secondary rounded-pill border border-secondary border-opacity-50 fw-semibold px-4 shadow-sm hover-lift">
            <i class="bi bi-arrow-left me-2"></i>Back to Groups
        </a>
    </div>
</div>

@if (!string.IsNullOrEmpty(ViewBag.Error))
{
    <div class="alert alert-warning d-flex align-items-center rounded-4 shadow-sm border-warning border-opacity-50 mb-4" role="alert">
        <i class="bi bi-exclamation-triangle-fill text-warning fs-4 me-3"></i>
        <div class="fw-semibold">
            @ViewBag.Error
        </div>
    </div>
}

<div class="card border-0 shadow-sm rounded-4 overflow-hidden mt-4">
    <div class="card-header bg-white border-bottom border-light px-4 py-3">
        <h5 class="fw-bold text-dark mb-0 d-flex align-items-center">
            <i class="bi bi-clock-history text-primary me-3 fs-4"></i> Past Records
        </h5>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light text-secondary">
                <tr>
                    <th class="ps-4">Date</th>
                    <th>Student Name</th>
                    <th>Group</th>
                    <th class="text-end pe-4">Status</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var record in Model)
                    {
                        var statusClass = record.AttendanceStatus == "Present" ? "bg-success" :
                                          record.AttendanceStatus == "Absent" ? "bg-danger" :
                                          record.AttendanceStatus == "Late" ? "bg-warning text-dark" : "bg-info text-dark";
                        <tr>
                            <td class="ps-4 fw-semibold text-secondary">
                                <i class="bi bi-calendar-check me-2 opacity-50"></i>@record.Date.ToString("dd MMM yyyy HH:mm")
                            </td>
                            <td class="fw-bold text-dark">@record.StudentName</td>
                            <td><span class="badge bg-light text-secondary border px-2 py-1">@record.GroupName</span></td>
                            <td class="text-end pe-4">
                                <span class="badge @statusClass rounded-pill px-3 py-2 fw-semibold">
                                    @record.AttendanceStatus
                                </span>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-5">
                            <i class="bi bi-folder-x fs-2 text-muted opacity-50 mb-2 d-block"></i>
                            No attendance records found for this group yet.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>