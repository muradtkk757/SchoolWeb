@model IEnumerable<Academy.BLL.DTOs.GroupDto>

@{
    ViewData["Title"] = "Record Attendance - Select Group";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="display-6 fw-bold text-dark mb-0">Class Attendance</h1>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success d-flex align-items-center rounded-4 shadow-sm border-success border-opacity-25" role="alert">
        <i class="bi bi-check-circle-fill text-success fs-4 me-3"></i>
        <div class="fw-semibold">
            @TempData["SuccessMessage"]
        </div>
    </div>
}

<div class="card border-0 shadow-sm rounded-4 overflow-hidden mt-4">
    <div class="card-header bg-white border-bottom border-light py-3 px-4">
        <h5 class="card-title fw-bold text-dark mb-0"><i class="bi bi-person-lines-fill text-primary me-2"></i> Manage Groups</h5>
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light text-secondary">
                <tr>
                    <th class="ps-4">Group Name</th>
                    <th>Teacher</th>
                    <th>Students Count</th>
                    <th class="text-end pe-4">Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    foreach (var group in Model)
                    {
                        var studentCount = group.Students?.Count() ?? 0;
                        <tr>
                            <td class="ps-4 fw-bold text-dark">
                                <i class="bi bi-box me-1 opacity-50 text-secondary"></i> @group.Name
                            </td>
                            <td>@group.TeacherName</td>
                            <td>
                                <span class="badge rounded-pill text-bg-secondary bg-opacity-10 text-secondary px-3">@studentCount Students</span>
                            </td>
                            <td class="text-end pe-4">
                                @if (studentCount > 0)
                                {
                                    <div class="d-flex justify-content-end gap-2">
                                        <a href="/TeacherPanel/Attendance/ViewPast?groupId=@group.Id" class="btn btn-sm btn-outline-dark rounded-pill px-3 fw-semibold">
                                            <i class="bi bi-clock-history me-1"></i> History
                                        </a>
                                        <a href="/TeacherPanel/Attendance/Take?groupId=@group.Id" class="btn btn-sm btn-primary rounded-pill px-3 fw-semibold">
                                            <i class="bi bi-check2-circle me-1"></i> Take Today
                                        </a>
                                    </div>
                                }
                                else
                                {
                                    <button class="btn btn-sm btn-outline-secondary rounded-pill px-3" disabled>No Students</button>
                                }
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="4" class="text-center text-muted py-5">
                            <i class="bi bi-slash-circle fs-2 text-muted opacity-50 mb-2 d-block"></i>
                            No groups found to take attendance.
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>