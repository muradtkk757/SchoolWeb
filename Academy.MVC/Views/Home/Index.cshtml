@{
    ViewData["Title"] = "Academy Home";
}

<!-- Hero Section -->
<div class="position-relative overflow-hidden text-white rounded-5 my-4 shadow-lg border border-light border-opacity-10" style="background: linear-gradient(135deg, #0f172a 0%, #1e1b4b 100%); min-height: 520px;">
    <div class="position-absolute top-0 end-0 p-5 opacity-10" style="transform: scale(2.2) translate(10%, 15%);">
        <i class="bi bi-rocket-takeoff-fill" style="font-size: 25rem; color: #38bdf8;"></i>
    </div>
    
    <div class="row align-items-center py-4 py-md-5 g-0 h-100">
        <div class="col-lg-7 p-4 p-md-5 z-1 d-flex flex-column justify-content-center h-100">
            <span class="badge w-auto d-inline-block bg-primary bg-opacity-25 text-info px-3 py-2 ms-0 mb-4 rounded-pill border border-info border-opacity-25" style="width:fit-content; max-width: max-content;">
                <i class="bi bi-stars"></i> Next-Gen Education Platform
            </span>
            <h1 class="display-3 fw-bold lh-1 mb-4 text-white" style="letter-spacing: -1.5px;">
                Empower Your <span style="color: #38bdf8;">Future</span> With Us.
            </h1>
            <p class="lead fw-normal text-white-50 mb-5 fs-4" style="max-width: 600px;">
                Quality education, interactive learning, and experienced mentors to guide you towards a successful professional path.
            </p>
            <div class="d-flex gap-3 flex-wrap">
                <a href="#features" class="btn btn-primary btn-lg px-4 py-3 rounded-pill fw-bold text-white shadow-lg d-flex align-items-center gap-2">
                    Explore Features <i class="bi bi-arrow-down-short fs-5"></i>
                </a>
            </div>
        </div>
        
        <div class="col-lg-5 p-4 p-md-5 z-1" id="login-section">
            <!-- Login Card -->
            <div class="card shadow-lg border border-secondary border-opacity-25 bg-white bg-opacity-10 backdrop-blur rounded-5 overflow-hidden">
                <div class="card-body p-4 p-md-5">
                    <div class="text-center mb-4">
                        <div class="bg-primary d-inline-flex align-items-center justify-content-center shadow-lg rounded-4 mb-3" style="width: 64px; height: 64px; transform: rotate(-5deg);">
                            <i class="bi bi-shield-lock-fill fs-2 text-white" style="transform: rotate(5deg);"></i>
                        </div>
                        <h3 class="text-white fw-bold mb-1">Portal Login</h3>
                        <p class="text-white-50 small mb-0">Secure access for students and staff</p>
                    </div>
                    
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger bg-danger bg-opacity-25 text-white border border-danger border-opacity-50 rounded-4 d-flex align-items-center p-3 mb-4" role="alert">
                            <i class="bi bi-exclamation-triangle-fill fs-4 me-3 text-danger"></i>
                            <div>
                                <small class="fw-bold d-block">Authentication Failed</small>
                                <small class="text-white-75">@TempData["ErrorMessage"]</small>
                            </div>
                        </div>
                    }

                    <form asp-controller="Account" asp-action="Login" method="post">
                        <div class="form-floating mb-3">
                            <input type="text" name="Username" class="form-control border border-secondary border-opacity-25 text-white shadow-none rounded-4 auth-input" id="floatingInput" placeholder="Username" required style="background: rgba(255,255,255,0.05); backdrop-filter: blur(5px);"/>
                            <label for="floatingInput" class="text-white-50 auth-label"><i class="bi bi-person me-1"></i> Username</label>
                        </div>
                        <div class="form-floating mb-4 position-relative">
                            <input type="password" name="Password" class="form-control border border-secondary border-opacity-25 text-white shadow-none rounded-4 auth-input" id="floatingPassword" placeholder="Password" required style="background: rgba(255,255,255,0.05); backdrop-filter: blur(5px);" />
                            <label for="floatingPassword" class="text-white-50 auth-label"><i class="bi bi-key me-1"></i> Password</label>
                        </div>
                        <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill fw-bold shadow-lg mt-2 py-3 d-flex justify-content-center align-items-center auth-btn">
                            <i class="bi bi-box-arrow-in-right fs-5 me-2"></i> Access Account
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Stats Section -->
<div class="container-fluid px-0 mb-5">
    <div class="row g-4 text-center">
        <div class="col-6 col-md-3">
            <div class="bg-white p-4 rounded-5 shadow-sm border border-light h-100 feature-card transition-all">
                <i class="bi bi-person-check-fill fs-1 text-primary mb-2 opacity-50"></i>
                <h2 class="display-5 fw-bold text-dark mb-0">50+</h2>
                <p class="text-muted fw-semibold mb-0" style="font-size: 0.85rem;">Expert Teachers</p>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="bg-white p-4 rounded-5 shadow-sm border border-light h-100 feature-card transition-all">
                <i class="bi bi-people-fill fs-1 text-success mb-2 opacity-50"></i>
                <h2 class="display-5 fw-bold text-dark mb-0">2K+</h2>
                <p class="text-muted fw-semibold mb-0" style="font-size: 0.85rem;">Active Students</p>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="bg-white p-4 rounded-5 shadow-sm border border-light h-100 feature-card transition-all">
                <i class="bi bi-trophy-fill fs-1 text-warning mb-2 opacity-50"></i>
                <h2 class="display-5 fw-bold text-dark mb-0">100%</h2>
                <p class="text-muted fw-semibold mb-0" style="font-size: 0.85rem;">Success Rate</p>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="bg-white p-4 rounded-5 shadow-sm border border-light h-100 feature-card transition-all">
                <i class="bi bi-collection-play-fill fs-1 text-info mb-2 opacity-50"></i>
                <h2 class="display-5 fw-bold text-dark mb-0">30+</h2>
                <p class="text-muted fw-semibold mb-0" style="font-size: 0.85rem;">Courses Available</p>
            </div>
        </div>
    </div>
</div>

<!-- Features Section -->
<div id="features" class="py-5 border-top border-light border-opacity-50">
    <div class="text-center mb-5">
        <span class="badge bg-primary bg-opacity-10 text-primary py-2 px-3 fw-bold text-uppercase tracking-wider rounded-pill mb-2 border border-primary border-opacity-25">Why Choose Us</span>
        <h2 class="display-5 fw-bold mt-2 text-dark" style="letter-spacing: -1px;">Quality in Every Aspect</h2>
    </div>
    
    <div class="row g-4">
        <div class="col-md-4">
            <div class="card h-100 border border-light shadow-sm rounded-5 overflow-hidden feature-card transition-all">
                <div class="card-body p-4 p-lg-5 text-start position-relative">
                    <div class="icon-box bg-primary text-white rounded-4 mb-4 d-inline-flex align-items-center justify-content-center shadow-lg" style="width: 60px; height: 60px;">
                        <i class="bi bi-laptop fs-4"></i>
                    </div>
                    <h4 class="fw-bold text-dark mb-3">Modern Curriculum</h4>
                    <p class="text-muted mb-0 lh-lg" style="font-size: 0.95rem;">Our syllabus is dynamically updated to fit modern industry standards, ensuring students learn the most relevant and high-demand skills.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border border-light shadow-sm rounded-5 overflow-hidden feature-card transition-all">
                <div class="card-body p-4 p-lg-5 text-start">
                    <div class="icon-box bg-success text-white rounded-4 mb-4 d-inline-flex align-items-center justify-content-center shadow-lg" style="width: 60px; height: 60px;">
                        <i class="bi bi-people fs-4"></i>
                    </div>
                    <h4 class="fw-bold text-dark mb-3">Vibrant Community</h4>
                    <p class="text-muted mb-0 lh-lg" style="font-size: 0.95rem;">Become part of a globally connected network of ambitious students and mentors who support your journey from day one.</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100 border border-light shadow-sm rounded-5 overflow-hidden feature-card transition-all">
                <div class="card-body p-4 p-lg-5 text-start">
                    <div class="icon-box bg-warning text-white rounded-4 mb-4 d-inline-flex align-items-center justify-content-center shadow-lg" style="width: 60px; height: 60px;">
                        <i class="bi bi-briefcase fs-4"></i>
                    </div>
                    <h4 class="fw-bold text-dark mb-3">Career Readiness</h4>
                    <p class="text-muted mb-0 lh-lg" style="font-size: 0.95rem;">Receive practical experience, 1-on-1 portfolio reviews, and intensive interview preparation directly from industry veterans.</p>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .backdrop-blur { backdrop-filter: blur(15px); -webkit-backdrop-filter: blur(15px); }
    .tracking-wider { letter-spacing: 0.15em; }

    /* Auth Form Improvements */
    .auth-input:focus {
        border-color: #38bdf8 !important;
        box-shadow: 0 0 0 4px rgba(56, 189, 248, 0.15) !important;
        background: rgba(255,255,255,0.1) !important;
    }
    .auth-input::placeholder { color: transparent !important; }
    .form-floating > .auth-input:focus ~ .auth-label,
    .form-floating > .auth-input:not(:placeholder-shown) ~ .auth-label {
        color: #38bdf8 !important;
        transform: scale(.85) translateY(-.5rem) translateX(.15rem);
    }
    
    .auth-btn {
        background-color: #2563eb; 
        border: none;
        transition: all 0.3s;
    }
    .auth-btn:hover {
        background-color: #1d4ed8;
        transform: translateY(-2px);
        box-shadow: 0 10px 20px rgba(37, 99, 235, 0.3) !important;
    }

    /* Cards */
    .feature-card { transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
    .feature-card:hover {
        transform: translateY(-8px);
        box-shadow: 0 20px 40px -5px rgba(0,0,0,.1) !important;
        border-color: rgba(37, 99, 235, 0.2) !important;
    }
    .icon-box { transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
    .feature-card:hover .icon-box { transform: scale(1.1) rotate(5deg); }
</style>
